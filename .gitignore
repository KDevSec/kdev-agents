# macOS
.DS_Store

# Linux
*~
.fuse_hidden*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment
.env
.env.local

# Python
__pycache__/
*.pyc
.playwright-mcp

# Node / build
node_modules/
dist/
bridge/*.cjs

# KDev / OMC runtime
.omc/

# References 源码项目 (不提交开源项目的 clone)
# 但保留分析文档 (.md)
docs/skills/kdev-code-graph/references/Understand-Anything/
docs/skills/kdev-code-graph/references/graphify/
docs/skills/kdev-code-graph/references/code-review-graph/
docs/skills/kdev-code-graph/references/ops-codegraph-tool/
# 允许 references 目录下的 .md 文档被提交
!docs/skills/kdev-code-graph/references/*.md
# 根目录 references 不提交 (使用 / 开头表示根目录)
/references/

# Claude Code 本地调试产物（仅忽略仓库根目录的 .kdev/；
# 允许子目录里的 .kdev 作为测试 fixture 被跟踪，靠下面的 negation 放行）
/.kdev/
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/*.lock
sandbox/*

# Git worktrees (本地隔离工作区，不跟踪)
/.worktrees/

# eval fixture：.kdev/ 测试数据，必须跟踪
!plugins/kdev-memory/evals/fixtures/**/.kdev/
!plugins/kdev-memory/evals/fixtures/**/.kdev/**

# 但 fixture 里的 hook 运行时产物不跟踪（state/ 是 UserPromptSubmit 去重状态、checkpoints/ 是 PreCompact 快照）
plugins/kdev-memory/evals/fixtures/**/.kdev/memory/state/
plugins/kdev-memory/evals/fixtures/**/.kdev/memory/checkpoints/

# skill-creator dev artifacts: 只跟踪用例定义（evals.json / eval_metadata.json / trigger-eval.json），
# 跑 run 的产物（response / grading / timing / benchmark / review.html / skill-snapshot）不入库
plugins/*/evals/**/old_skill/
plugins/*/evals/**/with_skill/
plugins/*/evals/**/without_skill/
plugins/*/evals/**/benchmark.json
plugins/*/evals/**/benchmark.md
plugins/*/evals/**/review.html
plugins/*/evals/**/feedback.json
plugins/*/evals/**/skill-snapshot/

# skill workspace 临时产物（venv / 跑测试日志），只跟踪用例 JSON
plugins/*/skills/*-workspace/.venv/
plugins/*/skills/*-workspace/*.log
# skill-creator iteration 产物（outputs / grading / benchmark / review.html 每次跑都重生成）
plugins/*/skills/*-workspace/iteration-*/
# skill-creator trigger-eval 输入（每次跑可能调整 query，不入库）
plugins/*/skills/*-workspace/trigger-eval.json

# kdev-ingestor venv
plugins/kdev-code-graph/ingestor/.venv/
plugins/kdev-code-graph/ingestor/*.egg-info/
plugins/kdev-code-graph/ingestor/.pytest_cache/
plugins/kdev-code-graph/ingestor/.coverage
